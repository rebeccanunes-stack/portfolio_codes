#include <iostream>
using namespace std; 

void fazAlgo2() { 
  int y = 10; // variável local na pilha 
  cout << "fazAlgo2: y = " << y << endl; 
  } 

void fazAlgo() { 
  int x = 5; // variável local na pilha 
  fazAlgo2(); 
  cout << "fazAlgo: x = " << x << endl; 
} 

int main() { 
  int a = 3, b = 4; // variáveis locais na pilha 
  fazAlgo(); 
  cout << "main: a = " << a << ", b = " << b << endl; 
} 
